{
  "compilerOptions": {
    "rootDirs": ["src"],
    "outDir": "dist",

    "target": "ES2023",
    "lib": ["ES2023"],

    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,

    "types": ["node"],

    "experimentalDecorators": true,
    "emitDecoratorMetadata": true
  }
}
